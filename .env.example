DOMAIN=azathd.ru

# --- Portal (web UI + federated search only) ---
REGISTRY_SUBDOMAIN=registry

# --- PyPI (dedicated endpoint for pip/uv/poetry/CI) ---
PYPI_SUBDOMAIN=pypi
PYPI_HOST=pypi.azathd.ru
PYPI_INDEX_URL=https://pypi.azathd.ru/root/pypi/+simple/
PYPI_TRUSTED_HOST=pypi.azathd.ru

# --- Other registries ---
DOCKER_SUBDOMAIN=docker
NPM_SUBDOMAIN=npm
OPENVSX_SUBDOMAIN=openvsx
OPENVSX_GALLERY_URL=https://openvsx.azathd.ru/vscode/gallery

# Harbor proxy project used in pull commands
HARBOR_PROXY_PROJECT=dockerhub
DOCKERHUB_USER=
DOCKERHUB_TOKEN=

# Open VSX backend
OPENVSX_POSTGRES_DB=openvsx
OPENVSX_POSTGRES_USER=openvsx
OPENVSX_POSTGRES_PASSWORD=openvsx

